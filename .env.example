# SaintSal Labs v2 — Environment Variables
# Copy to .env.local for local dev. Set all in Vercel dashboard for production.
# !! Never commit real values — this file contains placeholders only !!

# ── App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://saintsallabs.com
NEXT_PUBLIC_API_URL=https://saintsallabs.com

# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_HOOK_SECRET=your-hook-secret

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI Providers (server-only) ───────────────────────────────────
