ANTHROPIC_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
EXA_SERVICE_KEY=

# ── Voice ────────────────────────────────────────────────────────
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# ── External APIs (server-only) ──────────────────────────────────
GODADDY_API_KEY=
GODADDY_API_SECRET=
